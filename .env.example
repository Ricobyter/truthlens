# ===== Core =====
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB (free tier: https://mongodb.com/atlas)
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/truthlens?retryWrites=true&w=majority

# ===== AI / Search =====
# Groq — FREE 14,400 req/day (https://console.groq.com/keys)
GROQ_API_KEY=gsk_...

# Tavily — FREE 1,000 req/month (https://tavily.com)
TAVILY_API_KEY=tvly-...

# ===== Auth (NextAuth.js v5) =====
# Generate with: npx auth secret  — or any random string
AUTH_SECRET=replace-with-long-random-string

# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== Cloudinary (avatar storage) =====
# Free tier: 25GB storage (https://cloudinary.com/users/register/free)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== Stripe (payments) =====
# Get keys at: https://dashboard.stripe.com/apikeys
# Use sk_test_... / pk_test_... for development
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret: https://dashboard.stripe.com/webhooks
# For local dev use: stripe listen --forward-to localhost:3000/api/payment/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
